# --- Application ---
APP_NAME=Bayan AI
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Database ---
DATABASE_URL=postgresql+psycopg2://bayan:bayan@localhost:5432/bayan_ai

# --- Security ---
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- AI (Google Gemini) ---
# Comma-separated list enables automatic key rotation on quota (429) errors.
GEMINI_API_KEYS=your-key-1,your-key-2
GEMINI_CHAT_MODEL=gemini-2.0-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004

# --- RAG ---
RAG_TOP_K=5
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
INDEXES_DIR=./data/indexes
UPLOADS_DIR=./data/uploads

# --- Limits ---
DAILY_MESSAGE_LIMIT=100
MAX_MESSAGE_CHARS=4000

# --- Email (verification / password reset) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@bayan.ai
FRONTEND_URL=http://localhost:5173
